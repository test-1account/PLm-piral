{
  "name": "plm-microfrontend-workspace",
  "version": "1.0.0",
  "description": "PLM Microfrontend Workspace - Piral Architecture",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "demo": "vite --config vite.demo.config.ts --port 3000",
    "demo:build": "vite build --config vite.demo.config.ts --root .",
    "install:all": "npm install --workspaces",
    "build:all": "npm run build --workspaces --if-present",
    "build:design-system": "npm run build --workspace=packages/design-system",
    "storybook": "npm run storybook --workspace=packages/design-system",
    "build-storybook": "npm run build-storybook --workspace=packages/design-system",
    "start:shell": "npm run start --workspace=packages/shell",
    "start:product-mfe": "npm run start --workspace=packages/product-management-mfe",
    "start:document-mfe": "npm run start --workspace=packages/document-control-mfe",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:all": "npm run test --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "clean:all": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^13.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "plm-shell": "^1.0.0"
  }
}
